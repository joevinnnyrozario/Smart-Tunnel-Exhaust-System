# Flask Environment
FLASK_ENV=development
SECRET_KEY=your-secret-key-here

# MQTT Configuration
MQTT_SERVER=192.168.0.233
MQTT_PORT=1883
MQTT_TOPIC=tunnel/sensors

# Database Configuration
DATABASE_URL=sqlite:///tunnel_data.db

# Sensor Settings
SENSOR_REFRESH_INTERVAL=5000
SENSOR_HISTORY_SIZE=60

# Model Settings
MODEL_TYPE=random_forest
AQI_THRESHOLD=0.5
FAN_MIN_SPEED=0
FAN_MAX_SPEED=255

# Sensor Alert Thresholds
MQ2_WARNING_THRESHOLD=200
MQ2_CRITICAL_THRESHOLD=500
MQ3_WARNING_THRESHOLD=150
MQ3_CRITICAL_THRESHOLD=400

# Environmental Thresholds
TEMP_MIN=10
TEMP_MAX=40
HUMIDITY_MIN=20
HUMIDITY_MAX=90
